datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  transactions Transaction[]
}

enum TransactionType {
  INCOME
  EXPENSE
}

enum Category {
  FOOD
  SHOPPING
  TRAVEL
  BILLS
  SALARY
  FREELANCING
  INVESTMENT
  OTHER
}

model Transaction {
  id        String          @id @default(uuid())
  userId    String
  title     String
  amount    Float
  type      TransactionType
  category  Category
  notes     String?
  updatedAt DateTime        @updatedAt
  user      User            @relation(fields: [userId], references: [id])

}
